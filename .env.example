# ── Carrot — Variables de entorno ──

# PostgreSQL
DATABASE_URL="postgresql://carrot_user:TU_PASSWORD@localhost:5432/carrot_db"

# JWT Secret (generar uno seguro para producción)
JWT_SECRET="cambiar-en-produccion"

# Auth
NEXTAUTH_URL="https://thnet.com/carrot"

# Next.js — basePath para servir bajo /carrot (dejar vacío en desarrollo)
# NEXT_PUBLIC_BASE_PATH="/carrot"

# Meraki API
# MERAKI_API_KEY=""
# MERAKI_ORG_ID=""
# MERAKI_BASE_URL="https://api.meraki.com/api/v1"

# Cron de monitoreo (secret para proteger el endpoint)
# CRON_SECRET=""

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_EMAIL="mailto:admin@example.com"

# Entorno
NODE_ENV="development"
PORT=3000
