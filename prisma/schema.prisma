generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────
enum Role {
  ADMIN
  MODERADOR
  TECNICO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

// ─── USUARIOS ───────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  rol       Role     @default(TECNICO)
  esMesa    Boolean  @default(false) // Rol secundario: puede atender consultas en Mesa de Ayuda
  activo    Boolean  @default(true)
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prediosCreados      Predio[]          @relation("CreadorPredio")
  asignaciones        Asignacion[]
  comentarios         Comentario[]
  actividades         Actividad[]
  notificaciones      Notificacion[]
  tareasCreadas       TareaCalendario[] @relation("CreadorTarea")
  tareasAsignadas     TareaCalendario[] @relation("AsignadoTarea")
  instructivosCreados Instructivo[]     @relation("CreadorInstructivo")
  actasSubidas        Acta[]            @relation("SubidorActa")
  espaciosCreados     EspacioTrabajo[]  @relation("CreadorEspacio")
  monitoreos          MonitoreoPostCambio[]
  pushSubscriptions   PushSubscription[]
  delegacionesDadas   Delegacion[] @relation("DelegadorUser")
  delegacionesRecibidas Delegacion[] @relation("DelegadoUser")
  facturas             ReporteFacturacion[] @relation("GeneradorReporte")
  papeleraItems        PapeleraItem[] @relation("EliminadorPapelera")
  chatsCreados         ChatConversacion[] @relation("CreadorChat")
  chatsAtendidos       ChatConversacion[] @relation("AgenteChat")
  mensajesChat         ChatMensaje[]
  equiposAsignados     Equipo[]           @relation("EquipoAsignado")
  permisosEstado       PermisoEstadoUsuario[]
  registrosAcceso      RegistroAcceso[]
  accesosEspacio       AccesoEspacio[]
}

// ─── DELEGACIONES (visibilidad cruzada de tareas) ──
model Delegacion {
  id          String   @id @default(cuid())
  delegadorId String   // El usuario que comparte sus tareas
  delegadoId  String   // El usuario que puede ver las tareas del delegador
  activo      Boolean  @default(true)
  notas       String?
  createdAt   DateTime @default(now())

  delegador   User     @relation("DelegadorUser", fields: [delegadorId], references: [id], onDelete: Cascade)
  delegado    User     @relation("DelegadoUser", fields: [delegadoId], references: [id], onDelete: Cascade)

  @@unique([delegadorId, delegadoId])
  @@index([delegadoId])
  @@index([delegadorId])
}

// ─── ESTADOS PERSONALIZADOS ────────────────────────
model EstadoConfig {
  id      String  @id @default(cuid())
  nombre  String
  clave   String  @unique
  color   String  @default("#3b82f6")
  orden   Int     @default(0)
  entidad String  @default("PREDIO")
  activo  Boolean @default(true)

  predios         Predio[]
  permisos        PermisoEstado[]
  permisosUsuario PermisoEstadoUsuario[]
}

// ─── ESPACIOS DE TRABAJO ────────────────────────────
model EspacioTrabajo {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  color       String   @default("#3b82f6")
  icono       String   @default("folder")
  orden       Int      @default(0)
  activo      Boolean  @default(true)

  parentId    String?
  parent      EspacioTrabajo?  @relation("EspacioHijos", fields: [parentId], references: [id], onDelete: Cascade)
  hijos       EspacioTrabajo[] @relation("EspacioHijos")

  creadorId   String
  creador     User     @relation("CreadorEspacio", fields: [creadorId], references: [id], onDelete: Cascade)

  predios     Predio[]
  accesos     AccesoEspacio[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([orden])
}

// ─── PREDIOS ────────────────────────────────────────
model Predio {
  id              String    @id @default(cuid())
  nombre          String
  codigo          String?   @unique
  direccion       String?
  ciudad          String?
  tipo            String?
  latitud         Float?
  longitud        Float?
  notas           String?
  orden           Int       @default(0)
  fechaProgramada DateTime?
  prioridad       Prioridad @default(MEDIA)
  seccion         String?

  // ── Campos del Cronograma (estilo ClickUp) ──
  incidencias       String?   // Código de incidencias (NI-000135...)
  lacR              String?   // SI/NO
  cue               String?   // CUE (código único establecimiento)
  fechaDesde        DateTime? // Fecha inicio
  fechaHasta        DateTime? // Fecha fin
  ambito            String?   // Urbano/Rural
  equipoAsignado    String?   // TH09, TH01, etc.
  provincia         String?   // Santa Fe, Buenos Aires, etc.
  cuePredio         String?   // CUE del predio
  gpsPredio         String?   // Coordenadas GPS
  tipoRed           String?   // Tipo de red
  codigoPostal      String?   // Código postal
  caracteristicaTelefonica String? // Característica telefónica
  telefono          String?   // Teléfono
  lab               String?   // LAB
  nombreInstitucion String?   // Nombre de la institución
  correo            String?   // Correo electrónico
  fechaActualizacion DateTime? // Última actualización del registro
  camposExtra       Json?     // Campos dinámicos adicionales

  merakiNetworkId   String?
  merakiOrgId       String?
  merakiNetworkName String?

  espacioId String?
  espacio   EspacioTrabajo? @relation(fields: [espacioId], references: [id], onDelete: SetNull)

  estadoId  String?
  estado    EstadoConfig? @relation(fields: [estadoId], references: [id], onDelete: SetNull)
  creadorId String?
  creador   User?         @relation("CreadorPredio", fields: [creadorId], references: [id], onDelete: SetNull)

  equipos      Equipo[]
  etiquetas    PredioEtiqueta[]
  comentarios  Comentario[]
  asignaciones Asignacion[]
  tareas       TareaCalendario[]
  actas        Acta[]
  monitoreos   MonitoreoPostCambio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merakiNetworkId])
  @@index([estadoId])
  @@index([codigo])
  @@index([provincia])
  @@index([equipoAsignado])
  @@index([espacioId])
  @@index([estadoId, fechaActualizacion])
  @@index([creadorId])
}

// ─── EQUIPOS (STOCK) ────────────────────────────────
model Equipo {
  id          String  @id @default(cuid())
  nombre      String
  descripcion String?
  numeroSerie String? @unique
  modelo      String?
  marca       String?
  cantidad    Int     @default(1)
  estado      String  @default("DISPONIBLE")
  categoria   String?
  ubicacion   String?
  notas         String?
  fecha         String?
  etiqueta      String?
  etiquetaColor String?
  predioId      String?
  predio        Predio? @relation(fields: [predioId], references: [id], onDelete: SetNull)
  asignadoId    String?
  asignado      User?   @relation("EquipoAsignado", fields: [asignadoId], references: [id], onDelete: SetNull)

  comentarios  Comentario[]
  asignaciones Asignacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([categoria])
  @@index([predioId])
  @@index([asignadoId])
}

// ─── ETIQUETAS ──────────────────────────────────────
model Etiqueta {
  id     String @id @default(cuid())
  nombre String @unique
  color  String @default("#3b82f6")

  predios PredioEtiqueta[]
}

model PredioEtiqueta {
  predioId   String
  etiquetaId String
  predio     Predio   @relation(fields: [predioId], references: [id], onDelete: Cascade)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([predioId, etiquetaId])
}

// ─── COMENTARIOS ────────────────────────────────────
model Comentario {
  id        String   @id @default(cuid())
  contenido String
  userId    String
  predioId  String?
  equipoId  String?
  usuario   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  predio    Predio?  @relation(fields: [predioId], references: [id], onDelete: Cascade)
  equipo    Equipo?  @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([predioId])
  @@index([equipoId])
  @@index([userId])
  @@index([predioId, createdAt])
}

// ─── ASIGNACIONES ───────────────────────────────────
model Asignacion {
  id       String  @id @default(cuid())
  tipo     String
  notas    String?
  userId   String
  predioId String?
  equipoId String?
  usuario  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  predio   Predio? @relation(fields: [predioId], references: [id], onDelete: Cascade)
  equipo   Equipo? @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([predioId])
  @@index([userId, predioId])
}

// ─── NOTIFICACIONES ─────────────────────────────────
model Notificacion {
  id        String  @id @default(cuid())
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean @default(false)
  enlace    String?
  entidad   String?
  entidadId String?
  userId    String
  usuario   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─── ACTIVIDAD ──────────────────────────────────────
model Actividad {
  id          String   @id @default(cuid())
  accion      String
  descripcion String?
  entidad     String
  entidadId   String
  metadata    Json?
  userId      String
  usuario     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entidad])
  @@index([createdAt])
  @@index([entidad, createdAt])
  @@index([userId, createdAt])
  @@index([entidadId])
}

// ─── TAREAS CALENDARIO ──────────────────────────────
model TareaCalendario {
  id             String    @id @default(cuid())
  titulo         String
  descripcion    String?
  fecha          DateTime
  fechaFin       DateTime? // Para eventos de varios días
  horaInicio     String?
  horaFin        String?
  tipo           String    @default("TAREA")
  categoria      String    @default("GENERAL") // INSTALACION, MANTENIMIENTO, REUNION, VISITA, GUARDIA, RECORDATORIO, GENERAL
  prioridad      Prioridad @default(MEDIA)
  completada     Boolean   @default(false)
  color          String    @default("#3b82f6")
  todoElDia      Boolean   @default(false)
  ubicacion      String?
  notificarPush  Boolean   @default(true)
  esAsignada     Boolean   @default(false)
  notas          String?   @db.Text
  creadorId      String
  asignadoId     String?
  predioId       String?
  creador        User      @relation("CreadorTarea", fields: [creadorId], references: [id])
  asignado       User?     @relation("AsignadoTarea", fields: [asignadoId], references: [id])
  predio         Predio?   @relation(fields: [predioId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([asignadoId])
  @@index([creadorId])
  @@index([asignadoId, fecha])
  @@index([creadorId, fecha])
  @@index([completada, fecha])
  @@index([categoria])
}

// ─── INSTRUCTIVOS ───────────────────────────────────
model Instructivo {
  id           String  @id @default(cuid())
  titulo       String
  descripcion  String?
  contenido    String? @db.Text
  videoUrl     String?
  videoNombre  String?
  videoRuta    String?
  videoTipo    String?
  videoSize    Int?
  imagenNombre String?
  imagenRuta   String?
  imagenTipo   String?
  imagenSize   Int?
  categoria    String  @default("General")
  orden        Int     @default(0)
  activo       Boolean @default(true)
  creadoPorId  String
  creador      User    @relation("CreadorInstructivo", fields: [creadoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria])
}

// ─── ACTAS ──────────────────────────────────────────
model Acta {
  id            String  @id @default(cuid())
  nombre        String
  descripcion   String?
  archivoNombre String
  archivoTipo   String
  archivoRuta   String
  archivoSize   Int
  version       Int     @default(1)
  predioId      String?
  predio        Predio? @relation(fields: [predioId], references: [id], onDelete: SetNull)
  subidoPorId   String
  subidoPor     User    @relation("SubidorActa", fields: [subidoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([predioId])
}

// ─── MONITOREO POST-CAMBIO DE ESTADO ─────────────────
model MonitoreoPostCambio {
  id              String   @id @default(cuid())
  predioId        String
  predio          Predio   @relation(fields: [predioId], references: [id], onDelete: Cascade)
  userId          String
  usuario         User     @relation(fields: [userId], references: [id])
  estadoAnterior  String?  // Nombre del estado anterior
  estadoNuevo     String?  // Nombre del estado nuevo
  networkId       String?  // merakiNetworkId del predio
  orgId           String?  // merakiOrgId del predio

  checksRealizados Int     @default(0)  // 0, 1, 2
  maxChecks        Int     @default(2)
  intervaloMin     Int     @default(15) // minutos entre checks
  proximoCheck     DateTime             // cuándo ejecutar el próximo
  completado       Boolean @default(false)
  resultados       Json?               // últimos resultados de checks

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completado, proximoCheck])
  @@index([userId])
}

// ─── PUSH SUBSCRIPTIONS ──────────────────────────────
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  usuario  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── REPORTES DE FACTURACIÓN ─────────────────────────
model ReporteFacturacion {
  id              String   @id @default(cuid())
  semana          String   // Ej: "2026-W11" (año-semana ISO)
  fechaDesde      DateTime // Inicio del período (lunes)
  fechaHasta      DateTime // Fin del período (viernes)
  totalTareas     Int      // Total de tareas CONFORME en el período
  resumen         Json     // Array de { tecnicoId, tecnicoNombre, cantidad, tareaIds }
  csvRuta         String?  // Ruta al CSV generado
  csvNombre       String?  // Nombre del archivo CSV
  generadoEn      String   @default("AUTO") // AUTO o MANUAL
  generadoPorId   String
  generadoPor     User     @relation("GeneradorReporte", fields: [generadoPorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([semana])
  @@index([createdAt])
}

// ─── PERMISOS POR SECCIÓN ────────────────────────────
model PermisoSeccion {
  id        String  @id @default(cuid())
  seccion   String  // clave de sección: tareas, calendario, stock, etc.
  rol       Role
  ver       Boolean @default(true)
  crear     Boolean @default(false)
  editar    Boolean @default(false)
  eliminar  Boolean @default(false)
  exportar  Boolean @default(false)

  @@unique([seccion, rol])
  @@index([seccion])
}

// ─── VISIBILIDAD DE ESTADOS POR ROL ────────────────
model PermisoEstado {
  id        String @id @default(cuid())
  estadoId  String
  rol       Role
  visible   Boolean @default(true)

  estado    EstadoConfig @relation(fields: [estadoId], references: [id], onDelete: Cascade)

  @@unique([estadoId, rol])
  @@index([estadoId])
  @@index([rol])
}

// ─── VISIBILIDAD DE ESTADOS POR USUARIO ─────────────
model PermisoEstadoUsuario {
  id        String  @id @default(cuid())
  estadoId  String
  userId    String
  visible   Boolean @default(true)

  estado    EstadoConfig @relation(fields: [estadoId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([estadoId, userId])
  @@index([userId])
  @@index([estadoId])
}

// ─── CAMPOS PERSONALIZADOS ─────────────────────────
model CampoPersonalizado {
  id     String @id @default(cuid())
  clave  String @unique  // clave interna (sanitizada del nombre)
  nombre String          // Nombre visible (etiqueta)
  tipo   String @default("text") // text, number, date, select, badge
  opciones String[] @default([])  // Opciones para select/badge
  ancho  Int    @default(100)
  orden  Int    @default(0)
  activo Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([activo, orden])
}

// ─── CONFIGURACIÓN VISTA COMPARTIDA ─────────────────
model ConfiguracionVista {
  id        String   @id @default(cuid())
  clave     String   @unique  // "col-config-tareas", "col-config-espacio"
  config    Json                // Array de {id, visible, order, width}
  updatedAt DateTime @updatedAt
  updatedBy String?             // userId del último que modificó
}

// ─── HOSPEDAJES ─────────────────────────────────────
model Hospedaje {
  id         String  @id @default(cuid())
  ubicacion  String
  nombre     String
  tipo       String?
  garage     String?
  telefono   String?
  provincia  String?
  notas      String?
  activo     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provincia])
  @@index([ubicacion])
  @@index([activo])
}

// ─── PAPELERA (elementos eliminados) ────────────────
model PapeleraItem {
  id          String   @id @default(cuid())
  tipo        String   // PREDIO, EQUIPO, ACTA, CALENDARIO, INSTRUCTIVO, HOSPEDAJE, etc.
  nombre      String   // Nombre/título del elemento eliminado
  datos       Json     // Snapshot completo del registro antes de eliminar
  eliminadoPorId String
  eliminadoPor   User  @relation("EliminadorPapelera", fields: [eliminadoPorId], references: [id])

  createdAt   DateTime @default(now())

  @@index([tipo])
  @@index([eliminadoPorId])
  @@index([createdAt])
}

// ─── CHAT MESA DE AYUDA ─────────────────────────────
model ChatConversacion {
  id          String    @id @default(cuid())
  asunto      String?   // Opcional, se auto-genera si no se provee
  estado      String    @default("ABIERTA") // ABIERTA (esperando), EN_CURSO, CERRADA
  creadorId   String    // El técnico que inicia
  agenteId    String?   // El usuario Mesa que toma la conversación
  creador     User      @relation("CreadorChat", fields: [creadorId], references: [id], onDelete: Cascade)
  agente      User?     @relation("AgenteChat", fields: [agenteId], references: [id], onDelete: SetNull)
  mensajes    ChatMensaje[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cerradoAt   DateTime?

  @@index([creadorId])
  @@index([agenteId])
  @@index([estado])
  @@index([createdAt])
}

model ChatMensaje {
  id              String   @id @default(cuid())
  contenido       String   @db.Text
  conversacionId  String
  autorId         String
  archivoUrl      String?  // Ruta relativa del archivo subido
  archivoNombre   String?  // Nombre original del archivo
  archivoTipo     String?  // MIME type (image/jpeg, video/mp4, audio/webm, application/zip)
  archivoTamanio  Int?     // Tamaño en bytes
  conversacion    ChatConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  autor           User @relation(fields: [autorId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([conversacionId, createdAt])
  @@index([autorId])
}

// ─── ACCESO POR USUARIO A ESPACIOS DE TRABAJO ──────
model AccesoEspacio {
  id         String   @id @default(cuid())
  userId     String
  espacioId  String

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  espacio    EspacioTrabajo @relation(fields: [espacioId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([userId, espacioId])
  @@index([userId])
  @@index([espacioId])
}

// ─── REGISTRO DE ACCESOS (AUDITORÍA) ────────────────
model RegistroAcceso {
  id        String   @id @default(cuid())
  userId    String
  accion    String   // LOGIN, CONSULTA_PREDIO, CONSULTA_MERAKI
  detalle   String?  // Ej: nombre del predio, IP de login
  metadata  Json?    // Info extra: predioId, userAgent, etc.
  ip        String?

  usuario   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([accion, createdAt])
  @@index([createdAt])
}
